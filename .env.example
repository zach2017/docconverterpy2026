# ────────────────────────────────────────────────────────────────
# Document Conversion Service – Environment Configuration
# Copy to .env and customise as needed.
# ────────────────────────────────────────────────────────────────

# ── Feature flags ──────────────────────────────────────────────
ENABLE_API=true
ENABLE_SQS=true
ENABLE_RABBITMQ=true
ENABLE_KAFKA=true
ENABLE_TEMPORAL=true
USE_TEMPORAL_WORKFLOWS=true            # route all jobs through Temporal

# ── SQS ────────────────────────────────────────────────────────
SQS_ENDPOINT_URL=http://localstack:4566
SQS_QUEUE_NAME=docconv-jobs
SQS_POLL_INTERVAL=5

# ── S3 ─────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localstack:4566
S3_OUTPUT_BUCKET=docconv-output

# ── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=docconv
RABBITMQ_PASS=docconv
RABBITMQ_QUEUE=docconv-jobs

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=docconv-jobs
KAFKA_GROUP_ID=docconv-group

# ── Temporal.io ────────────────────────────────────────────
TEMPORAL_HOST=temporal-server:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=docconv-tasks
TEMPORAL_WORKFLOW_TIMEOUT=3600
TEMPORAL_ACTIVITY_TIMEOUT=600
TEMPORAL_RETRY_MAX_ATTEMPTS=3

# ── AWS creds (LocalStack) ────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ── Tuning ─────────────────────────────────────────────────────
CHUNK_SIZE=65536
TMP_DIR=/tmp/docconv
LOG_LEVEL=INFO
API_PORT=8080
